# ============== 核心配置 ==============
API_VERSION=1.0.0
ENV=dev
DEBUG=True

# ============== 数据库配置 ==============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=fastapi_template

# ============== Redis配置 ==============
REDIS_URL=redis://localhost:6379/0

# ============== RabbitMQ配置 ==============
RABBITMQ_URL=amqp://admin:admin@localhost:5672/fastapi

# ============== LLM配置 ==============
# 选择启用的LLM提供商 (deepseek/moonshot/glm/ark/openai)
# 多个提供商用逗号分隔
ENABLED_LLM_PROVIDERS=deepseek,moonshot

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Moonshot
MOONSHOT_API_KEY=your_moonshot_key
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# GLM (智谱AI)
ZHIPUAI_API_KEY=your_zhipuai_key
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# Ark (火山引擎)
ARK_API_KEY=your_ark_key
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# OpenAI (可选)
OPENAI_API_KEY=your_openai_key
OPENAI_API_BASE=https://api.openai.com/v1

# ============== Celery配置 ==============
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_RESULT_EXPIRES=3600

# ============== 日志配置 ==============
FILE_LOG_ENABLED=False
DB_ECHO=True
DB_ECHO_POOL=False
THIRD_PARTY_LOG_LEVEL=WARNING
SQLALCHEMY_LOG_LEVEL=WARNING
STARTUP_VERBOSE=False

# ============== 安全配置 ==============
SECRET_KEY=your_secret_key_here_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============== 可选配置（按需启用） ==============
# 腾讯云COS（文件存储）
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_REGION=ap-guangzhou

# 微信支付（可选）
# WECHAT_MP_APP_ID=
# WECHAT_MP_APP_SECRET=
# WECHAT_PAY_MCHID=
# WECHAT_PAY_APIV3_KEY=

# 飞书（可选）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
