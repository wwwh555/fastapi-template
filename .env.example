# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=db_name

# Redis配置
REDIS_URL=redis://localhost:6379/0

# RabbitMQ配置
RABBITMQ_URL=amqp://admin:admin@localhost:5672/fastapi

# API配置
API_VERSION=1.0.0
ENV=dev
ALLOWED_HOSTS=["localhost", "localhost:8000"]

# LLM Provider API Keys

# Moonshot (月之暗面) - 用于 kimi-k2-250711, moonshot-v1-8k 等模型
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# ARK (火山引擎/豆包) - 用于 doubao-1-5-lite-32k-250115 等模型
ARK_API_KEY=your_ark_api_key_here
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# GLM (智谱AI) - 用于智谱相关模型
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# DeepSeek - 用于 DeepSeek 相关模型
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# OpenAI (可选)
OPENAI_API_KEY=your_openai_api_key_here

# Celery配置
CELERY_RESULT_EXPIRES=3600

# 腾讯云配置 (可选)
TENCENT_APP_ID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_TTS_REGION=ap-beijing

# 腾讯云COS配置 (可选)
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=
TENCENT_COS_BASE_URL=

# 飞书应用配置 (可选)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=

# 微信小程序配置 (可选)
WECHAT_MP_ENV_VERSION=
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=

# 微信支付配置 (可选)
WECHAT_PAY_MCHID=
WECHAT_PAY_APIV3_KEY=
WECHAT_PAY_APPID=
WECHAT_PAY_NOTIFY_URL=
WECHAT_REFUND_NOTIFY_URL=

# 太忆记忆管理API (可选)
TIMEM_API_KEY=
TIMEM_ENABLED=true
